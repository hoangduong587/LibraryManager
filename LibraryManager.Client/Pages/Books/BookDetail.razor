@page "/books/{Id:int}"

@using LibraryManager.Shared.Dtos
@using LibraryManager.Client.Services
@inject IBookService BookService
@inject BorrowService BorrowService
@inject NavigationManager Nav

<h3>Book Details</h3>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (Book == null)
{
    <p class="text-danger">Book not found.</p>
}
else
{
    <div class="card p-3 shadow-sm">

        <h4>@Book.Title</h4>

        <table class="table table-bordered mt-3">
            <tbody>
                <tr>
                    <th>ID</th>
                    <td>@Book.Id</td>
                </tr>
                <tr>
                    <th>Genre</th>
                    <td>@Book.Genre</td>
                </tr>
                <tr>
                    <th>Author</th>
                    <td>@Book.Author</td>
                </tr>
                <tr>
                    <th>Publish Year</th>
                    <td>@Book.PublishYear</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>@Book.Description</td>
                </tr>
                <tr>
                    <th>Location</th>
                    <td>@Book.Location</td>
                </tr>
                <tr>
                    <th>Borrower</th>
                    <td>@(Book.BorrowerUserName ?? "None")</td>
                </tr>
                <tr>
                    <th>Availability</th>
                    <td>@(Book.Availability ? "Available" : "Borrowed")</td>
                </tr>
            </tbody>
        </table>

        <button class="btn btn-primary me-2"
                @onclick="BorrowBook"
                disabled="@(Book.Availability == false)">
            Borrow This Book
        </button>

        <button class="btn btn-warning ms-2" @onclick="EditBook">Edit Book</button>
        <button class="btn btn-secondary" @onclick="GoBack">Back to List</button>
    </div>
}

@if (ShowDialog)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Notification</h5>
                </div>

                <div class="modal-body">
                    <p>@DialogMessage</p>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="CloseDialog">OK</button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private BookDto? Book;
    private bool isLoading = true;

    private bool ShowDialog { get; set; }
    private string DialogMessage { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        Book = await BookService.GetBookByIdAsync(Id);
        isLoading = false;
    }

    private void GoBack()
    {
        Nav.NavigateTo("/books");
    }

    private void EditBook()
    {
        Nav.NavigateTo($"/books/edit/{Id}");
    }

    private async Task BorrowBook()
    {
        var result = await BorrowService.BorrowBookAsync(Book.Id);

        if (result == "__UNAUTHORIZED__")
        {
            Nav.NavigateTo("/login");
            return;
        }

        // Show modal dialog with message
        DialogMessage = result;
        ShowDialog = true;

        // Refresh book details after borrow attempt
        Book = await BookService.GetBookByIdAsync(Id);
    }

    private void CloseDialog()
    {
        ShowDialog = false;
    }
}
