@page "/books/edit/{Id:int}"

@using LibraryManager.Shared.Dtos
@using LibraryManager.Client.Services
@inject IBookService BookService
@inject NavigationManager Nav

<h3>Edit Book</h3>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (book == null)
{
    <p class="text-danger">Book not found.</p>
}
else
{
    <EditForm Model="@book" OnValidSubmit="HandleUpdate">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Title</label>
            <InputText @bind-Value="book.Title" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Genre</label>
            <InputText @bind-Value="book.Genre" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Author</label>
            <InputText @bind-Value="book.Author" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Publish Year</label>
            <InputNumber @bind-Value="book.PublishYear" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Description</label>
            <InputTextArea @bind-Value="book.Description" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Location</label>
            <InputText @bind-Value="book.Location" class="form-control" />
        </div>

        <button class="btn btn-primary" type="submit">Save Changes</button>
        <button class="btn btn-secondary ms-2" @onclick="Cancel">Cancel</button>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private UpdateBookDto? book;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var existing = await BookService.GetBookByIdAsync(Id);

        if (existing != null)
        {
            book = new UpdateBookDto
            {
                Title = existing.Title,
                Genre = existing.Genre,
                Author = existing.Author,
                PublishYear = existing.PublishYear,
                Description = existing.Description,
                Location = existing.Location
            };
        }

        isLoading = false;
    }

    private async Task HandleUpdate()
    {
        if (book == null)
            return;

        var success = await BookService.UpdateBookAsync(Id, book);

        if (success)
            Nav.NavigateTo("/books");
    }

    private void Cancel()
    {
        Nav.NavigateTo("/books");
    }
}
